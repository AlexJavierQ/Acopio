# Connection string de Neon (pooled, con ?pgbouncer=true&connection_limit=1)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"
# Connection string de Neon DIRECT (sin pooler) — obligatorio para migraciones
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

JWT_SECRET="cambia-esto-en-produccion-acopio-2026"

# Origen permitido para CORS en producción (URL del cliente desplegado)
CORS_ORIGIN="https://acopio-client.vercel.app"

PORT=4000
